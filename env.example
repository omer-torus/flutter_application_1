# =====================================================
# Turizm Gezi Rehberi - Environment Variables
# =====================================================

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here

# Google Places API
GOOGLE_PLACES_KEY=your-google-places-api-key-here

# Optional: AI Backend URL (Python service)
AI_BACKEND_URL=http://localhost:8000

# =====================================================
# NASIL KULLANILIR:
# =====================================================
# 1. Bu dosyayı .env olarak kopyala
# 2. Gerçek API key'lerini yukarıdaki alanlara yapıştır
# 3. Flutter'ı şu şekilde çalıştır:
#    flutter run --dart-define-from-file=.env
# =====================================================


